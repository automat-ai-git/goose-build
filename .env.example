# Модель Goose (должна быть скачана в Ollama)
# Лучший выбор для агента: devstral:24b (создан для coding agents, tool use)
# Альтернатива: qwen3-coder:30b (сильнее в коде, тяжелее)
GOOSE_MODEL=devstral:24b

# GID группы docker на хосте
# Проверить командой: stat -c '%g' /var/run/docker.sock
DOCKER_GID=999

# Caddy — домен и авторизация (добавить в .env n8n-install)
GOOSE_HOSTNAME=goose.твой-домен.com
GOOSE_USERNAME=admin
# Сгенерировать хэш: docker exec caddy caddy hash-password --plaintext "ваш_пароль"
GOOSE_PASSWORD_HASH=

# Plane MCP
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=
PLANE_BASE_URL=http://plane-app-api-1:8000
