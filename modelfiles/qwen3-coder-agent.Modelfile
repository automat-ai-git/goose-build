# Modelfile для Qwen3 Pro 128k — параметры инференса под Goose на NVIDIA GPU
#
# Обновить существующую модель:
#   docker exec -i ollama ollama create qwen36-pro-128k -f - < ~/goose/modelfiles/qwen3-coder-agent.Modelfile
#
# Запустить сессию Goose с этой моделью:
#   goose session --recipe ~/.config/goose/recipes/qwen3-coder.yaml

FROM qwen36-pro-128k:latest

PARAMETER num_ctx 65536
PARAMETER temperature 0
PARAMETER top_k 20
PARAMETER top_p 0.95
PARAMETER repeat_penalty 1.0
PARAMETER presence_penalty 0
PARAMETER use_mlock true

# Системный контекст — передаётся через Goose (рецепт + .goosehints)
# SYSTEM не задаём здесь — Goose строит его сам

# ───────────────────────────────────────────────────────────────
# Настройки Ollama-сервера (docker-compose ollama service):
#
#   environment:
#     - OLLAMA_FLASH_ATTENTION=1
#     - OLLAMA_KV_CACHE_TYPE=q8_0
#     - OLLAMA_NUM_PARALLEL=1
#     - OLLAMA_MAX_LOADED_MODELS=1
#     - OLLAMA_KEEP_ALIVE=5h
#     - OLLAMA_CONTEXT_LENGTH=65536
#     - CUDA_VISIBLE_DEVICES=0
#     - NVIDIA_VISIBLE_DEVICES=0
# ───────────────────────────────────────────────────────────────
