# Modelfile для Qwen3-Coder — параметры инференса под Goose на NVIDIA GPU
#
# Создать модель:
#   ollama create qwen3-coder-agent -f modelfiles/qwen3-coder-agent.Modelfile
#
# Запустить сессию Goose с этой моделью:
#   goose session --recipe ~/.config/goose/recipes/qwen3-coder.yaml

FROM qwen3.6-coder:27b-instruct-q8_0

# Большое окно: агент видит длинные логи, документацию и код одновременно
PARAMETER num_ctx 65536

# Низкая температура: точность в bash/docker командах важнее креативности
PARAMETER temperature 0.2

# Держать модель в VRAM (не выгружать между запросами)
PARAMETER use_mlock true

# Системный контекст — передаётся через Goose (рецепт + .goosehints)
# SYSTEM не задаём здесь — Goose строит его сам

# ───────────────────────────────────────────────────────────────
# Настройки Ollama-сервера (docker-compose ollama service):
#
#   environment:
#     - OLLAMA_FLASH_ATTENTION=1
#     - OLLAMA_KV_CACHE_TYPE=q8_0
#     - OLLAMA_NUM_PARALLEL=1
#     - OLLAMA_MAX_LOADED_MODELS=1
#     - OLLAMA_KEEP_ALIVE=5h
#     - OLLAMA_CONTEXT_LENGTH=65536   # совпадает с num_ctx выше
#     - CUDA_VISIBLE_DEVICES=0
#     - NVIDIA_VISIBLE_DEVICES=0
# ───────────────────────────────────────────────────────────────
